rules_version = '2';

// ============================================================
// Firestore security rules — Family Shopping List
// Deploy: Firebase Console > Firestore Database > Rules tab > paste > Publish
//
// No accounts, no household codes — this is a single shared list for
// everyone who has the app link. The only gate is Firebase Anonymous
// Auth, which the app signs every visitor into automatically and
// invisibly (no login screen). This blocks raw/unauthenticated API
// abuse while keeping the app itself completely login-free for users.
// ============================================================
service cloud.firestore {
  match /databases/{database}/documents {

    match /items/{itemId} {
      allow read, create, update, delete: if request.auth != null;
    }

    // Small shared settings doc (e.g. meta/budget, meta/shopper) — same
    // everyone-can-edit model as items, just used for app-wide settings
    // instead of list items.
    match /meta/{docId} {
      allow read, write: if request.auth != null;
    }

    // Recurring items (e.g. "Milk every Sunday") — same everyone-can-edit
    // model as items.
    match /recurringItems/{docId} {
      allow read, create, update, delete: if request.auth != null;
    }
  }
}
