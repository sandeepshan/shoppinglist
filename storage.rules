rules_version = '2';

// ============================================================
// Firebase Storage security rules — Family Shopping List
// Deploy: Firebase Console > Storage > Rules tab > paste > Publish
// (or `firebase deploy --only storage` if using the CLI)
// ============================================================
service firebase.storage {
  match /b/{bucket}/o {
    match /receipts/{householdId}/{fileName} {
      // anyone with the link can view (simplest for a family app); only signed-in
      // users can upload. Tighten further later if desired.
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
